{
  "manifest_version": 3,
  "name": "E-C connect",
  "version": "1.0.0",
  "description": "Cross-browser bookmarks sync for Edge and Chrome.",
  "permissions": [
    "bookmarks",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
